# Application Settings
APP_NAME="LLM Prompt Injection Firewall"
ENV="development"
DEBUG=true
HOST="127.0.0.1"
PORT=8000

# Database Settings
DATABASE_URL="sqlite:///./firewall.db"

# Firewall Configuration
# Modes: learning (log and allow), sanitize (log, clean, and forward), enforce (log and block high threats)
FIREWALL_MODE="learning"

# Threat Thresholds (0-100)
THRESHOLD_ALLOW=25
THRESHOLD_WARN=50
THRESHOLD_SANITIZE=75

# Authentication & Security
JWT_SECRET="super-secret-firewall-jwt-key-change-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
RATE_LIMIT_PER_MINUTE=60

# Downstream LLM API Configuration
# By default, if this is empty, the proxy will return simulated LLM completions for testing.
DOWNSTREAM_LLM_URL=""
DOWNSTREAM_LLM_API_KEY=""
